{
  "catalogue_name": "FashionSense Mock Store Catalogue",
  "version": "1.0",
  "currency": "EUR",
  "description": "Editable mock catalogue template for vision + chat-based clothing search. Stores can update items directly here or mirror the same columns in Excel/CSV and convert them into this JSON structure.",
  "editing_guidelines": {
    "one_item_per_object": true,
    "use_null_for_not_applicable_type_specific_fields": true,
    "keep_parser_fields_aligned_with_allowed_values": [
      "type",
      "color",
      "style",
      "pattern",
      "material",
      "fit",
      "gender",
      "age_group",
      "season",
      "occasion"
    ],
    "free_text_fields": [
      "name",
      "brand",
      "description",
      "sku",
      "image_url",
      "product_url",
      "tags"
    ]
  },
